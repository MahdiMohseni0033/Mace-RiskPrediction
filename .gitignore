# --- Datasets (do not commit raw or processed patient data) ---
datasets/
*.csv.gz
*.parquet
*.h5
*.hdf5

# --- Python virtual environment ---
.venv/
venv/
env/
ENV/

# --- Python bytecode / build artefacts ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# --- Jupyter / IPython ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Large model artefacts (re-generated by the pipeline) ---
*.joblib
*.pkl
*.pickle

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- OS / shell ---
*.tmp
*.log
*.bak

# --- Profile output (regenerable from data) ---
dataset_profile.txt

# --- Local Claude state ---
.claude/

